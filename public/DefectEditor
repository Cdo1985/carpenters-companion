<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Defect Scanner | West Victorian Trades</title>
    <style>
        :root {
            --brand: #2563eb;
            --defect: #ff0000;
            --dark: #1a1a1a;
        }

        body {
            font-family: sans-serif;
            background: var(--dark);
            color: white;
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        header {
            padding: 15px;
            background: #000;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #333;
        }

        /* Controls Area */
        .controls {
            padding: 10px;
            background: #222;
            display: flex;
            gap: 10px;
            z-index: 10;
        }

        .btn {
            flex: 1;
            padding: 12px;
            border-radius: 8px;
            border: none;
            font-weight: bold;
            text-transform: uppercase;
            cursor: pointer;
        }

        .btn-upload { background: var(--brand); color: white; }
        .btn-clear { background: #444; color: white; }

        /* Canvas Workspace */
        #container {
            flex: 1;
            position: relative;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        canvas {
            max-width: 100%;
            max-height: 100%;
            touch-action: none; /* Prevents scrolling while tagging */
        }

        .instruction {
            position: absolute;
            bottom: 20px;
            background: rgba(0,0,0,0.7);
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            pointer-events: none;
        }

        #fileInput { display: none; }
    </style>
</head>
<body>

    <header>
        <strong>DEFECT SCANNER</strong>
        <span id="counter" style="color: var(--defect)">0 DEFECTS</span>
    </header>

    <div class="controls">
        <button class="btn btn-upload" onclick="document.getElementById('fileInput').click()">📸 SNAP / UPLOAD</button>
        <button class="btn btn-clear" onclick="clearDefects()">RESET</button>
        <input type="file" id="fileInput" accept="image/*">
    </div>

    <div id="container">
        <canvas id="defectCanvas"></canvas>
        <div class="instruction">Tap photo to highlight a defect</div>
    </div>

    <script>
        const canvas = document.getElementById('defectCanvas');
        const ctx = canvas.getContext('2d');
        const fileInput = document.getElementById('fileInput');
        const counterDisplay = document.getElementById('counter');
        
        let img = new Image();
        let defects = [];

        // Handle Image Upload
        fileInput.onchange = (e) => {
            const file = e.target.files[0];
            const reader = new FileReader();
            reader.onload = (event) => {
                img.onload = () => {
                    // Set canvas size to match image aspect ratio
                    canvas.width = img.width;
                    canvas.height = img.height;
                    defects = []; // Reset markers for new photo
                    draw();
                };
                img.src = event.target.result;
            };
            reader.readAsDataURL(file);
        };

        // Handle Taps/Clicks to add defect markers
        canvas.addEventListener('pointerdown', (e) => {
            if (!img.src) return;

            const rect = canvas.getBoundingClientRect();
            const scaleX = canvas.width / rect.width;
            const scaleY = canvas.height / rect.height;
            
            const x = (e.clientX - rect.left) * scaleX;
            const y = (e.clientY - rect.top) * scaleY;

            defects.push({ x, y });
            draw();
        });

        function draw() {
            // 1. Clear and Draw Background Image
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.drawImage(img, 0, 0);

            // 2. Draw Defect Highlighters
            defects.forEach((defect, index) => {
                // Outer Glow/Circle
                ctx.beginPath();
                ctx.arc(defect.x, defect.y, 40, 0, Math.PI * 2);
                ctx.strokeStyle = "rgba(255, 0, 0, 0.8)";
                ctx.lineWidth = 8;
                ctx.stroke();

                // Inner Dot
                ctx.beginPath();
                ctx.arc(defect.x, defect.y, 10, 0, Math.PI * 2);
                ctx.fillStyle = "red";
                ctx.fill();

                // Label
                ctx.fillStyle = "white";
                ctx.font = "bold 40px sans-serif";
                ctx.fillText(`D-${index + 1}`, defect.x + 50, defect.y + 15);
            });

            counterDisplay.innerText = `${defects.length} DEFECTS FOUND`;
        }

        function clearDefects() {
            defects = [];
            draw();
        }
    </script>
</body>
</html>
